# Copy to .env in the project root before running `docker compose up`.
# docker-compose.yml reads these to configure all three services consistently.

POSTGRES_USER=inventory_user
POSTGRES_PASSWORD=inventory_pass
POSTGRES_DB=inventory_db

# Origins allowed to call the API, comma-separated, or * for any
CORS_ORIGINS=*

# Used at frontend build time so the React bundle knows where the API lives
VITE_API_URL=http://localhost:8000
