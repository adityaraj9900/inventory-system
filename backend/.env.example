# Copy this file to .env and fill in real values. Never commit the real .env file.

# Full SQLAlchemy/psycopg2 connection string
DATABASE_URL=postgresql://inventory_user:inventory_pass@db:5432/inventory_db

# Comma-separated list of allowed frontend origins, e.g.:
# CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173
CORS_ORIGINS=*

# Port the app listens on (most hosting platforms set this automatically)
PORT=8000
